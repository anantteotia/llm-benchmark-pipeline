# RocketRide engine connection (local Docker default)
ROCKETRIDE_URI=ws://localhost:5565
ROCKETRIDE_APIKEY=your_rocketride_apikey_if_required

# LLM provider keys (used by .pipe via ${ROCKETRIDE_*} substitution)
ROCKETRIDE_OPENAI_KEY=your_openai_api_key_here
ROCKETRIDE_ANTHROPIC_KEY=your_anthropic_api_key_here
ROCKETRIDE_GEMINI_KEY=your_google_api_key_here
